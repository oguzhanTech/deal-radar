{
  "name": "deal-radar",
  "version": "1.0.0",
  "private": true,
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "iOS >= 15",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "lighthouse:mobile": "lighthouse http://127.0.0.1:3000 --only-categories=performance --form-factor=mobile --screenEmulation.mobile --throttling-method=simulate --chrome-flags=\"--headless=new\" --output=html --output-path=./lighthouse-mobile-report.html --quiet"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.3",
    "@vercel/og": "^0.6.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.483.0",
    "next": "^15.3.1",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^4.5.2",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/web-push": "^3.6.4",
    "critters": "^0.0.23",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "lighthouse": "^12.8.2",
    "typescript": "^5.8.3"
  }
}
